# The private input files directory is for files that should not be included in
# Git or Docker, such as UMLS files.
input_files/private

# Python build/packaging artifacts (from the GitHub Python .gitignore).
__pycache__/
*.py[cod]
*.egg
*.egg-info/
.eggs/
build/
dist/
.venv/
.pytest_cache/
babel_downloads/
babel_outputs/
.snakemake/
.env
.idea
htmlcov/

# Source-impact detail files: generated locally for digging/sharing, but not committed —
# they grow roughly linearly with the source and are useless to commit for large additions.
# One row per identifier in an existing clique, so for a source the size of EMAPA the CSV alone
# is 1.2 MB. The other detail files in the same directory are committed when they are small
# enough to be worth reading in the diff; drop one by hand when it is not (EMAPA's new-xrefs.tsv,
# 464 KB).
docs/sources/*/impact-report/modified-cliques.json
docs/sources/*/impact-report/modified-cliques.csv

# Local scratch space for ad hoc files (analysis notebooks, one-off downloads, intermediates).
# Anchored to the repo root: unanchored, this also swallowed tests/data/, so every committed test
# fixture there had to be force-added.
/data/

# Build metadata regenerated by `uv sync` / setuptools; never committed.
*.egg-info/

# Coverage data written by `pytest --cov`.
.coverage
.coverage.*
htmlcov/

# Spreadsheet sources for the hand-curated manual concords. The .tsv the pipeline reads is
# committed; the Numbers/Excel file it was exported from is a 170 KB binary that diffs as a blob
# and is only useful on the maintainer's machine.
*.numbers
*.xlsx

# macOS Finder metadata.
.DS_Store
